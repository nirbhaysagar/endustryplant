# Supabase Database Configuration
# Duplicate this file to '.env.local' and populate it with your actual project keys
# from your Supabase Dashboard -> Project Settings -> API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-actual-supabase-anon-public-key
